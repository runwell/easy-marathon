{
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown"
  },
  "lint-staged": {
    "{*,.*}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
